<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Menu.Machine_watch.MainActivity_Machine_watch">

    <TableLayout
        android:id="@+id/tableLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:stretchColumns="*">

        <!-- 创建6行，每行8列的表格 -->
        <!-- 第一行 -->
        <TableRow>
            <TextView android:text="名称" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="状态" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="转速(rpm)" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="电压(V)" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="电流(A)" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="温度(℃)" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="圈数" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="电机状态" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
        </TableRow>

        <!-- 第二行，设置绿色背景 -->
        <TableRow android:background="@color/green">
            <TextView android:text="第一列" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
        </TableRow>

        <!-- 第三行 -->
        <TableRow>
            <TextView android:text="第二列" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
        </TableRow>

        <!-- 第四行 -->
        <TableRow>
            <TextView android:text="第三列" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
        </TableRow>

        <!-- 第五行 -->
        <TableRow>
            <TextView android:text="第四列" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
        </TableRow>

        <!-- 第六行 -->
        <TableRow>
            <TextView android:text="施肥电机" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
            <TextView android:text="" android:padding="8dp" android:textSize="18sp" android:background="@drawable/table_border"/>
        </TableRow>

    </TableLayout>

    <TextView
        android:id="@+id/page3title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="电机监控"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/machine_watch_backtomenu"
        android:layout_width="105dp"
        android:layout_height="109dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/back"
        android:contentDescription="返回"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/machine_watch_backtohome"
        android:layout_width="56dp"
        android:layout_height="59dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="@null"
        android:contentDescription="返回初始界面"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/home" />

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="10dp"
        android:background="#CCCCCC"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/page3title" />

</androidx.constraintlayout.widget.ConstraintLayout>
